// Schema do banco. Fonte da verdade das tabelas.
// Após editar: `npx prisma migrate dev --name <nome>` gera a migration + aplica.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Enums ----------

enum BaseUnit {
  G
  ML
  UN
}

enum ListStatus {
  DRAFT
  ACTIVE
  COMPLETED
}

// ---------- Domínio ----------

model Household {
  id                String   @id @default(cuid())
  name              String
  activeMemberCount Int      @default(1) // divisor das previsões; manual, NÃO derivado de users
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  users         User[]
  products      Product[]
  shoppingLists ShoppingList[]
  purchases     Purchase[]
}

model Product {
  id          String   @id @default(cuid())
  householdId String
  name        String
  category    String // texto livre com lista sugerida na UI (spec não define enum)
  baseUnit    BaseUnit
  packageSize Float // quanto de baseUnit vem em UMA embalagem
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  household         Household          @relation(fields: [householdId], references: [id], onDelete: Cascade)
  shoppingListItems ShoppingListItem[]
  purchaseItems     PurchaseItem[]

  @@unique([householdId, name]) // único por household
  @@index([householdId])
}

model ShoppingList {
  id          String     @id @default(cuid())
  householdId String
  name        String? // rótulo opcional ("Compra da semana")
  status      ListStatus @default(DRAFT)
  createdAt   DateTime   @default(now())
  completedAt DateTime?

  household Household          @relation(fields: [householdId], references: [id], onDelete: Cascade)
  items     ShoppingListItem[]
  purchase  Purchase? // uma lista concluída gera no máximo 1 compra

  @@index([householdId, status])
}

model ShoppingListItem {
  id              String  @id @default(cuid())
  shoppingListId  String
  productId       String
  plannedPackages Int
  checked         Boolean @default(false)

  shoppingList ShoppingList @relation(fields: [shoppingListId], references: [id], onDelete: Cascade)
  product      Product      @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@unique([shoppingListId, productId]) // mesmo produto não repete na mesma lista
  @@index([shoppingListId])
}

model Purchase {
  id             String   @id @default(cuid())
  householdId    String
  shoppingListId String   @unique // 1-para-1 com a lista que ela fecha
  date           DateTime
  establishment  String?
  total          Decimal  @db.Decimal(10, 2) // soma dos subtotais
  createdAt      DateTime @default(now())

  household    Household      @relation(fields: [householdId], references: [id], onDelete: Cascade)
  shoppingList ShoppingList   @relation(fields: [shoppingListId], references: [id], onDelete: Restrict)
  items        PurchaseItem[]

  @@index([householdId, date])
}

model PurchaseItem {
  id                  String  @id @default(cuid())
  purchaseId          String
  productId           String
  packages            Int // quantas embalagens compradas
  unitPrice           Decimal @db.Decimal(10, 2) // preço de UMA embalagem
  packageSizeSnapshot Float // congela Product.packageSize no momento da compra
  baseQuantity        Float // DERIVADO: packages × packageSizeSnapshot
  pricePerBaseUnit    Decimal @db.Decimal(12, 6) // DERIVADO: unitPrice / packageSizeSnapshot
  subtotal            Decimal @db.Decimal(10, 2) // DERIVADO: packages × unitPrice

  purchase Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([productId]) // histórico por produto
  @@index([purchaseId])
}

// ---------- Auth (modelos exigidos pelo better-auth) ----------
// Campos batem com o schema que o better-auth espera. O único extra é
// householdId em User (better-auth ignora campos que não conhece).

model User {
  id            String   @id
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  householdId String? // nullable: setado no /setup, depois do signup
  household   Household? @relation(fields: [householdId], references: [id])

  sessions Session[]
  accounts Account[]

  @@index([householdId])
}

model Session {
  id        String   @id
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                    String    @id
  userId                String
  accountId             String
  providerId            String
  password              String? // hash da senha (provider "credential")
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
}
